# Decision Graph — Environment Configuration
# Copy to .env and fill in. Never commit .env.
#
# Quick start: fill in the two required values below, then run:
#   npm run dg -- doctor

# ── Required ──────────────────────────────────────────────────────

# Anthropic API key for LLM calls (extract, link, evaluate, ask).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# GitHub Personal Access Token (classic PAT with public_repo scope).
# Create at: https://github.com/settings/tokens
# Rate limit with PAT: 5,000 req/hr
GITHUB_TOKEN=

# ── Optional ──────────────────────────────────────────────────────

# LLM model override (default: claude-sonnet-4-5)
# DG_MODEL=claude-sonnet-4-5

# Max LLM tool calls per step (default: 25)
# DG_TOOL_BUDGET=25

# Default workspace data directory (default: ./.decisiongraph/)
# DG_DATA_DIR=./.decisiongraph
